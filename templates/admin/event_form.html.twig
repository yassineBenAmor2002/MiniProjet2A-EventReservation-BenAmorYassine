{% extends 'base.html.twig' %}

{% block title %}
    {% if mode == 'edit' %}Modifier l'événement{% else %}Créer un événement{% endif %}
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse shadow-sm" style="min-height: 90vh;">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin_dashboard') }}">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="{{ path('admin_event_new') }}">
                            <i class="bi bi-plus-circle"></i> Nouvel Événement
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="{{ path('admin_logout') }}">
                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">{% if mode == 'edit' %}Modifier l'événement{% else %}Créer un événement{% endif %}</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Retour au dashboard
                    </a>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header py-3 bg-white">
                            <h6 class="m-0 font-weight-bold text-primary">Informations de l'événement</h6>
                        </div>
                        <div class="card-body">
                            <form method="post">
                                <div class="mb-3">
                                    <label for="title" class="form-label">Titre</label>
                                    <input type="text" name="title" id="title" class="form-control" value="{{ event.title ?? '' }}" required placeholder="Ex: Concert de jazz">
                                </div>

                                <div class="mb-3">
                                    <label for="description" class="form-label">Description</label>
                                    <textarea name="description" id="description" class="form-control" rows="4" required placeholder="Décrivez l'événement...">{{ event.description ?? '' }}</textarea>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="date" class="form-label">Date et Heure</label>
                                        <input type="datetime-local" name="date" id="date" class="form-control" value="{{ event.date ? event.date|date('Y-m-d\\TH:i') : '' }}" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="location" class="form-label">Lieu</label>
                                        <input type="text" name="location" id="location" class="form-control" value="{{ event.location ?? '' }}" required placeholder="Ex: Salle des fêtes">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label for="seats" class="form-label">Nombre de places</label>
                                        <input type="number" name="seats" id="seats" min="1" class="form-control" value="{{ event.seats ?? 1 }}" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label for="image" class="form-label">Image (URL)</label>
                                        <input type="text" name="image" id="image" class="form-control" value="{{ event.image ?? '' }}" placeholder="https://...">
                                    </div>
                                </div>

                                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                                    <a href="{{ path('admin_dashboard') }}" class="btn btn-light me-md-2">Annuler</a>
                                    <button type="submit" class="btn btn-primary px-4">
                                        <i class="bi bi-check-lg"></i> Enregistrer
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<style>
    .sidebar .nav-link { font-weight: 500; color: #333; padding: 0.5rem 1rem; }
    .sidebar .nav-link i { margin-right: 0.5rem; }
    .sidebar .nav-link.active { color: #007bff; }
</style>
{% endblock %}
