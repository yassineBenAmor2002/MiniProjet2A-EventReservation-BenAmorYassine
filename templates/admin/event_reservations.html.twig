{% extends 'base.html.twig' %}

{% block title %}Réservations pour {{ event.title }}{% endblock %}

{% block body %}
<h1>Réservations pour l'événement : {{ event.title }}</h1>

<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Nom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Date de réservation</th>
        </tr>
    </thead>
    <tbody>
        {% for reservation in reservations %}
            <tr>
                <td>{{ reservation.name }}</td>
                <td>{{ reservation.email }}</td>
                <td>{{ reservation.phone }}</td>
                <td>{{ reservation.createdAt|date('d/m/Y H:i') }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune réservation pour cet événement.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('admin_dashboard') }}">← Retour au dashboard</a>
{% endblock %}