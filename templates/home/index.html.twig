{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Liste des Événements</h1>
    <div class="row">
        {% for event in events %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    {% if event.image %}
                        <img src="{{ event.image }}" class="card-img-top" alt="{{ event.title }}" style="height: 200px; object-fit: cover;">
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ event.title }}</h5>
                        <p class="card-text text-muted">
                            <i class="bi bi-calendar-event"></i> {{ event.date|date('d/m/Y H:i') }}<br>
                            <i class="bi bi-geo-alt"></i> {{ event.location }}
                        </p>
                        <p class="card-text">{{ event.description|slice(0, 100) }}...</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-primary w-100">Voir Détails</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">Aucun événement disponible pour le moment.</div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
